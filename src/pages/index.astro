---
import "../styles/site.css";
import { navItems, openSourceProjects, profile } from "../content/profile";

const currentYear = new Date().getFullYear();
const ensureAccessibleText = (value: string | undefined | null, fallback: string) => {
	const normalized = value?.trim();
	return normalized && normalized.length > 0 ? normalized : fallback;
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Sean Liu | Home</title>
		<meta
			name="description"
			content="Personal site focused on the .NET ecosystem and open-source projects, showcasing ongoing engineering capabilities and project delivery."
		/>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to main content</a>

		<header class="global-nav">
			<div class="nav-inner">
				<a class="nav-brand" href="#top" aria-label="Back to top">
					<span class="brand-glyph" aria-hidden="true">●</span>
					<span>Sean Liu</span>
				</a>
				<nav class="nav-menu" aria-label="Primary">
					{
						navItems.map((item) => {
							const navLabel = ensureAccessibleText(item.label, "Section");
							return (
								<a class="nav-link" href={item.href} aria-label={navLabel}>
									{navLabel}
								</a>
							);
						})
					}
				</nav>
				<a class="nav-link nav-link-strong" href="mailto:idealhs@icloud.com"
					>Contact Me</a
				>
			</div>
		</header>

		<main id="main">
			<section id="top" class="hero hero-primary">
				<h1 class="hero-title reveal">
					<span class="hero-hello-wrap">
						<span id="hello-animated" class="hero-hello-text" aria-live="polite">Hello</span>
					</span>
					<span class="hero-name-line">
						<span class="hero-name-main">This is Sean</span>
						<span class="hero-name-role">{profile.role}</span>
					</span>
				</h1>
				<div class="hero-actions reveal delay-1">
					<a class="button button-primary" href="#opensource">View Open Source Projects</a>
					<a class="button button-link" href={profile.githubSource} target="_blank" rel="noreferrer"
						>Visit GitHub <span aria-hidden="true">›</span></a
					>
				</div>
			</section>

			<section id="about" class="section reveal delay-2">
				<div class="section-headline">
					<h2>About</h2>
				</div>
				<div class="about-intro">
					{profile.aboutIntroParagraphs.map((line) => <p>{line}</p>)}
				</div>
			</section>

			<section id="opensource" class="section reveal delay-2">
				<div class="section-headline">
					<h2>Open Source Projects</h2>
				</div>
				<div class="oss-grid">
					{
						openSourceProjects.map((project) => {
							const projectName = ensureAccessibleText(project.name, "Open Source Project");
							return (
								<article class="oss-card">
									<h3 aria-label={projectName}>{projectName}</h3>
									<p>{project.description}</p>
								<div class="oss-meta">{project.tech}</div>
								<div class="oss-actions">
									<a
										class="oss-action-link"
										href={project.link}
										target="_blank"
										rel="noreferrer"
										aria-label={`${projectName} repository`}
									>
										>Open Repository <span aria-hidden="true">›</span></a
									>
									{
										project.downloadAction ? (
											project.downloadAction.menuItems?.length ? (
												<details class="oss-dropdown">
													<summary
														class="oss-action-button"
														aria-label={ensureAccessibleText(
															project.downloadAction.label,
															`${projectName} download options`,
														)}
													>
														{ensureAccessibleText(project.downloadAction.label, "Download")}
														<span class="oss-dropdown-caret" aria-hidden="true">▾</span>
													</summary>
													<ul class="oss-dropdown-menu" aria-label={`${projectName} download options`}>
														{
															project.downloadAction.menuItems.map((item) => (
																<li>
																	{
																		item.url ? (
																			<a
																				href={item.url}
																				target="_blank"
																				rel="noreferrer"
																				aria-label={ensureAccessibleText(
																					item.label,
																					`${projectName} download link`,
																				)}
																			>
																				{ensureAccessibleText(item.label, "Download")}
																			</a>
																		) : (
																			<span>
																				{ensureAccessibleText(item.label, "Download")} ·{" "}
																				{item.statusText ?? "Coming soon"}
																			</span>
																		)
																	}
																</li>
															))
														}
													</ul>
												</details>
											) : project.downloadAction.url ? (
												<a
													class="oss-action-button"
													href={project.downloadAction.url}
													target="_blank"
													rel="noreferrer"
													aria-label={ensureAccessibleText(
														project.downloadAction.label,
														`${projectName} download`,
													)}
												>
													{ensureAccessibleText(project.downloadAction.label, "Download")}
												</a>
											) : (
												<span
													class="oss-action-button is-disabled"
													title={project.downloadAction.statusText ?? ""}
												>
													{ensureAccessibleText(project.downloadAction.label, "Download")}
												</span>
											)
										) : null
									}
								</div>
								</article>
							);
						})
					}
				</div>
				<div class="oss-more">
					<a
						class="button button-link"
						href="https://github.com/idealhs?tab=repositories"
						target="_blank"
						rel="noreferrer"
					>
						More <span aria-hidden="true">›</span>
					</a>
				</div>
			</section>
		</main>

		<footer class="page-footer">
			<div class="footer-inner">
				<span>{currentYear} Sean Liu</span>
			</div>
		</footer>
		<script is:inline>
			const rootNode = document.documentElement;
			const globalNav = document.querySelector(".global-nav");
			const heroPrimary = document.querySelector(".hero-primary");
			const syncGlobalNavHeight = () => {
				if (globalNav instanceof HTMLElement) {
					rootNode.style.setProperty("--global-nav-height", `${globalNav.offsetHeight}px`);
				}
			};
			const syncHeroHeight = () => {
				if (heroPrimary instanceof HTMLElement) {
					rootNode.style.setProperty("--hero-height", `${heroPrimary.offsetHeight}px`);
				}
			};

			let navHeightSyncQueued = false;
			const scheduleGlobalNavHeightSync = () => {
				if (navHeightSyncQueued) {
					return;
				}
				navHeightSyncQueued = true;
				window.requestAnimationFrame(() => {
					navHeightSyncQueued = false;
					syncGlobalNavHeight();
					syncHeroHeight();
				});
			};

			scheduleGlobalNavHeightSync();
			window.addEventListener("resize", scheduleGlobalNavHeightSync, { passive: true });

			if ("ResizeObserver" in window) {
				if (globalNav instanceof HTMLElement) {
					new ResizeObserver(scheduleGlobalNavHeightSync).observe(globalNav);
				}
				if (heroPrimary instanceof HTMLElement) {
					new ResizeObserver(scheduleGlobalNavHeightSync).observe(heroPrimary);
				}
			}

			const helloWords = [
				"Hello",
				"你好",
				"哈囉",
				"Hola",
				"Bonjour",
				"Hallo",
				"Ciao",
			];

			const helloNode = document.getElementById("hello-animated");
			const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
			if (helloNode instanceof HTMLElement && !prefersReducedMotion.matches) {
				let index = 0;
				let helloSwitchIntervalId = 0;
				let helloTransitionTimeoutId = 0;

				const switchWord = () => {
					index = (index + 1) % helloWords.length;
					helloNode.classList.add("hello-exit");

					if (helloTransitionTimeoutId !== 0) {
						window.clearTimeout(helloTransitionTimeoutId);
					}

					helloTransitionTimeoutId = window.setTimeout(() => {
						helloNode.textContent = helloWords[index];
						helloNode.classList.remove("hello-exit");
						helloNode.classList.add("hello-enter");
						window.requestAnimationFrame(() => helloNode.classList.remove("hello-enter"));
					}, 320);
				};

				const startHelloSwitch = () => {
					if (helloSwitchIntervalId === 0) {
						helloSwitchIntervalId = window.setInterval(switchWord, 4000);
					}
				};

				const stopHelloSwitch = () => {
					if (helloSwitchIntervalId !== 0) {
						window.clearInterval(helloSwitchIntervalId);
						helloSwitchIntervalId = 0;
					}
					if (helloTransitionTimeoutId !== 0) {
						window.clearTimeout(helloTransitionTimeoutId);
						helloTransitionTimeoutId = 0;
					}
				};

				startHelloSwitch();
				document.addEventListener("visibilitychange", () => {
					if (document.hidden) {
						stopHelloSwitch();
					} else {
						startHelloSwitch();
					}
				});
			}

			const installDropdowns = Array.from(document.querySelectorAll(".oss-dropdown")).filter(
				(dropdown) => dropdown instanceof HTMLDetailsElement,
			);

			if (installDropdowns.length > 0) {
				const closeOpenedDropdowns = (targetNode) => {
					const openedDropdowns = document.querySelectorAll(".oss-dropdown[open]");
					if (openedDropdowns.length === 0) {
						return;
					}

					for (const dropdown of openedDropdowns) {
						if (!(dropdown instanceof HTMLDetailsElement)) {
							continue;
						}
						if (targetNode instanceof Node && dropdown.contains(targetNode)) {
							continue;
						}
						dropdown.open = false;
					}
				};

				for (const dropdown of installDropdowns) {
					dropdown.addEventListener("focusout", () => {
						window.setTimeout(() => {
							const activeElement = document.activeElement;
							if (!(activeElement instanceof Node) || !dropdown.contains(activeElement)) {
								dropdown.open = false;
							}
						}, 0);
					});
				}

				document.addEventListener("pointerdown", (event) => {
					closeOpenedDropdowns(event.target);
				});
			}
		</script>
	</body>
</html>
